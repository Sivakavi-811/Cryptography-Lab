<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Vigenere Cipher</title>
  <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
  <style> .log-row{font-size:13px;margin:6px 0;} .output-box{white-space:pre-wrap;word-wrap:break-word;} </style>
  </head>
<body class="theme-ex1">
  <aside class="sidebar">
    <div class="logo">CRYPTO LAB</div>
    <nav>
      <ul>
        <li><a href="{{ url_for('root') }}">← Back to Home</a></li>
        <li style="margin-top: 20px; font-weight: bold; color: #aaa; font-size: 0.9rem;">Exercise 1-A (Classical Ciphers):</li>
        <li><a href="{{ url_for('ex1.vigenere_route') }}" style="color: #fff; font-weight: bold;">Vigenere</a></li>
        <li><a href="{{ url_for('ex1.affine_route') }}">Affine</a></li>
        <li><a href="{{ url_for('ex1.playfair_route') }}">Playfair</a></li>
        <li style="margin-top: 15px; font-weight: bold; color: #aaa; font-size: 0.9rem;">Exercise 1-B (Number Theory):</li>
        <li><a href="{{ url_for('ex1.extended_euclidean_route') }}">Extended Euclidean</a></li>
        <li><a href="{{ url_for('ex1.fermat_theorem_route') }}">Fermat's Little Theorem</a></li>
      </ul>
    </nav>
  </aside>
  <main class="content">
    <header><h1>Vigenere Cipher</h1></header>
    <section class="form-section">
      <form method="POST">
        <div class="form-group">
            <label>Key</label>
            <input type="text" name="key" value="{{ request.form.get('key', '') }}" required>
        </div>
        <div class="form-group">
            <label>Text</label>
            <textarea name="text" required>{{ request.form.get('text', '') }}</textarea>
        </div>
        <div style="display:flex; gap:10px;"><button type="submit" name="encrypt">Encrypt</button><button type="submit" name="decrypt">Decrypt</button></div>
      </form>

      {% if error %}<div class="error-message">{{ error }}</div>{% endif %}
      {% if result %}
        <div class="result-container">
          <h3>Result</h3>
          <div class="output-box">{{ result }}</div>

          {% if logs %}
            <h4 style="margin-top:20px;">Operations</h4>
            <div>
              {% for entry in logs %}
                <div class="log-row">{{ entry.pos }}: {{ entry.plain }} + {{ entry.key_char }} → {{ entry.cipher }}</div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    </section>
  </main>
</body>
</html>
